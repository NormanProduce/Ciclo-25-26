rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Colección de perfiles de usuario ──────────────────
    match /usuarios/{uid} {

      // Función helper: obtiene el rol del usuario autenticado
      function esAdmin() {
        return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'Administrador';
      }

      // Cualquier usuario autenticado puede leer su propio perfil
      allow get: if request.auth != null && request.auth.uid == uid;

      // Solo admins pueden listar todos los usuarios
      allow list: if request.auth != null && esAdmin();

      // Solo admins pueden crear perfiles de nuevos usuarios
      allow create: if request.auth != null && esAdmin();

      // Admins pueden editar cualquier perfil.
      // Usuarios normales solo pueden editar su propio perfil
      // y no pueden cambiar "rol" ni "activo".
      allow update: if request.auth != null && (
        esAdmin() ||
        (
          request.auth.uid == uid &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rol', 'activo'])
        )
      );

      // Solo admins pueden eliminar perfiles
      allow delete: if request.auth != null && esAdmin();
    }

  }
}
